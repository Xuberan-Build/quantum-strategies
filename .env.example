# =============================================================================
# Business Identity
# =============================================================================
BUSINESS_NAME=Your Business Name
NEXT_PUBLIC_DOMAIN=https://yourdomain.com

# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@yourdomain.com

# Transactional email sender (must be a Gmail address if using Gmail API)
SENDER_EMAIL=noreply@yourdomain.com
SENDER_NAME=Your Business Name

# =============================================================================
# Branding (used in email templates)
# =============================================================================
BRAND_PRIMARY=#030048
BRAND_ACCENT=#6C5CE7

# =============================================================================
# Feature Flags (set to true to enable)
# =============================================================================
FEATURE_AFFILIATES=false
FEATURE_EMAIL_SEQUENCES=false
FEATURE_SHEETS_CRM=false
FEATURE_BETA=false

# =============================================================================
# App URLs
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# If you split marketing/app across subdomains, set these separately:
# NEXT_PUBLIC_MARKETING_URL=https://yourdomain.com
# NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Stripe
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# =============================================================================
# OpenAI
# =============================================================================
OPENAI_API_KEY=sk-xxxxx

# =============================================================================
# Course Slideshow (iFrame-based slide player)
# =============================================================================
NEXT_PUBLIC_SLIDE_DECK_URL=https://your-slides-domain.vercel.app
NEXT_PUBLIC_SLIDE_DECK_VERSION=v1

# =============================================================================
# Google APIs (optional — for Gmail sending + Sheets CRM + Drive storage)
# =============================================================================

# Gmail Service Account (for sending transactional email)
GOOGLE_GMAIL_SERVICE_ACCOUNT_EMAIL=your-gmail-service-account@project.iam.gserviceaccount.com
GOOGLE_GMAIL_CLIENT_EMAIL=your-gmail-service-account@project.iam.gserviceaccount.com
GOOGLE_GMAIL_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# From addresses (Gmail API)
# GMAIL_FROM_EMAIL=hello@quantumstrategies.online   # transactional/affiliate emails
# GMAIL_FROM_NAME=Quantum Strategies

# Resend (for blueprint follow-up emails from austin@quantumstrategies.online)
# Sign up at resend.com, verify your domain, then paste the API key here.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Drive & Sheets Service Account
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=your-drive-service-account@project.iam.gserviceaccount.com
GOOGLE_DRIVE_CLIENT_EMAIL=your-drive-service-account@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# For production (Netlify/Vercel), use base64-encoded key files:
# GOOGLE_GMAIL_SERVICE_ACCOUNT_BASE64=base64_encoded_json_key
# GOOGLE_DRIVE_SERVICE_ACCOUNT_BASE64=base64_encoded_json_key

# Google Sheets CRM (requires FEATURE_SHEETS_CRM=true)
GOOGLE_SHEET_ID=your-crm-sheet-id

# Google Drive folder for uploaded documents
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# =============================================================================
# Admin
# =============================================================================
# Set to true to completely hide admin routes (useful in production if you
# manage via a separate deployment or never expose admin to the public)
ADMIN_DISABLED=false
